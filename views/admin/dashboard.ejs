<% var title = 'Dashboard Admin - Sistem Pengaduan Kos' %>
<%- include('../partials/header') %>

<div class="page-header">
  <h1>Dashboard Admin</h1>
</div>

<div class="stats">
  <div class="stat-card">
    <div class="number"><%= statistik.total %></div>
    <div class="label">Total Pengaduan</div>
  </div>
  <div class="stat-card">
    <div class="number"><%= statistik.menunggu %></div>
    <div class="label">Menunggu</div>
  </div>
  <div class="stat-card">
    <div class="number"><%= statistik.diproses %></div>
    <div class="label">Diproses</div>
  </div>
  <div class="stat-card">
    <div class="number"><%= statistik.selesai %></div>
    <div class="label">Selesai</div>
  </div>
</div>

<div class="filter-tabs">
  <a href="/admin/dashboard?status=semua" class="<%= statusFilter === 'semua' ? 'active' : '' %>">Semua</a>
  <a href="/admin/dashboard?status=menunggu" class="<%= statusFilter === 'menunggu' ? 'active' : '' %>">Menunggu</a>
  <a href="/admin/dashboard?status=diproses" class="<%= statusFilter === 'diproses' ? 'active' : '' %>">Diproses</a>
  <a href="/admin/dashboard?status=selesai" class="<%= statusFilter === 'selesai' ? 'active' : '' %>">Selesai</a>
</div>

<% if (daftarPengaduan.length === 0) { %>
  <div class="empty-state">
    <p>Tidak ada pengaduan dengan status ini.</p>
  </div>
<% } else { %>
  <% daftarPengaduan.forEach(function(p) { 
       const prioritas = p.prioritas || 'Sedang';
  %>
    <a href="/admin/pengaduan/<%= p.id %>" class="pengaduan-card">
      <div class="info">
        <h3><%= p.judul %></h3>
        <div class="meta">
          <%= p.nama_pelapor %> &middot; 
          Kamar <%= p.no_kamar || '-' %> &middot;
          Kategori: <%= p.kategori %> &middot;
          Prioritas:
          <span class="badge-prioritas <%= prioritas.toLowerCase() %>">
            <%= prioritas %>
          </span>
          &middot;
          <%= new Date(p.created_at).toLocaleString('id-ID') %>
        </div>
      </div>

      <span class="badge badge-<%= p.status %>">
        <% if (p.status === 'menunggu') { %>Menunggu
        <% } else if (p.status === 'diproses') { %>Diproses
        <% } else { %>Selesai
        <% } %>
      </span>
    </a>
  <% }) %>
<% } %>

<%- include('../partials/footer') %>