<% var title = 'Berita & Informasi Kos - Sistem Pengaduan Kos' %>
<%- include('../partials/header') %>

<div class="page-header">
  <h1>Kelola Berita &amp; Informasi Kos</h1>
</div>

<div class="detail-box" style="margin-bottom: 20px;">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/admin/pengumuman" method="POST">
    <div class="form-group">
      <label for="judul">Judul Pengumuman</label>
      <input type="text" id="judul" name="judul" placeholder="Contoh: Perbaikan Pipa Tandon Air" required>
    </div>

    <div class="form-group">
      <label for="isi">Isi Pengumuman</label>
      <textarea id="isi" name="isi" rows="4" placeholder="Tuliskan informasi untuk seluruh penghuni kos..." required></textarea>
    </div>

    <div class="form-group">
      <label for="tipe">Tipe</label>
      <select id="tipe" name="tipe">
        <option value="info">Info</option>
        <option value="peringatan">Peringatan</option>
      </select>
    </div>

    <button type="submit" class="btn">Terbitkan Pengumuman</button>
  </form>
</div>

<h2 style="margin-bottom: 12px;">Daftar Pengumuman</h2>

<% if (daftarPengumuman.length === 0) { %>
  <div class="empty-state">
    <p>Belum ada pengumuman yang dibuat.</p>
  </div>
<% } else { %>
  <% daftarPengumuman.forEach(function(p) { %>
    <div class="info-item info-item-<%= p.tipe %>" style="margin-bottom: 12px; background:#fff; border-radius:8px; box-shadow: 0 1px 6px rgba(0,0,0,0.06);">
      <div class="page-header" style="margin-bottom: 6px;">
        <h4>
          <%= p.tipe === 'peringatan' ? '⚠️' : 'ℹ️' %> <%= p.judul %>
        </h4>
        <form action="/admin/pengumuman/<%= p.id %>/hapus" method="POST">
          <button type="submit" class="btn-link" style="color:#c0392b;">Hapus</button>
        </form>
      </div>
      <p><%= p.isi %></p>
      <div class="detail-meta">Diterbitkan: <%= new Date(p.created_at).toLocaleString('id-ID') %></div>
    </div>
  <% }) %>
<% } %>

<%- include('../partials/footer') %>
